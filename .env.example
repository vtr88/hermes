# Optional. Leave unset for automatic per-thread session creation.
# HERMES_OPENCODE_SESSION_ID=ses_your_existing_session_id

HERMES_IMAP_URL=imaps://mail.example.com/INBOX
HERMES_SMTP_URL=smtps://mail.example.com:465
HERMES_MAIL_USER=hermes@example.com
HERMES_MAIL_PASS=REPLACE_WITH_APP_PASSWORD
HERMES_MAIL_FROM=hermes@example.com
HERMES_MAIL_TO=you@example.com
HERMES_ALLOW_FROM=you@example.com

HERMES_DB_PATH=build/hermes.db
HERMES_TOOL_TIMEOUT_SEC=300
HERMES_POLL_SECONDS=30

# Optional cost/budget tracking for email footer
HERMES_BUDGET_USD=25
